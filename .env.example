# Copy this file to .env and fill in real values for local development.
# On Railway, set these in the project Variables dashboard instead.

# GoHighLevel — required for /api/subscribe and /api/contact-form
GHL_PIT=pit-your-private-integration-token-here
GHL_LOCATION_ID=your-ghl-location-id

# ESV Bible API — required for /api/verse (daily.html verse popover)
ESV_API_KEY=optional-but-recommended

# Content-write API key — required for /api/content/* POST endpoints
API_KEY=set-a-long-random-string

# Optional: GitHub commit-back so added content persists across deploys
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO=iaormo/ianjamesormo.com
# GITHUB_BRANCH=main
